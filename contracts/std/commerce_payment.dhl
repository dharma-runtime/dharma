## Code

### Types
```dhl


struct PaymentAllocation
    public invoice_id: Ref<std.commerce.invoice>
    public amount_minor: Int
```

### Aggregate state
```dhl
aggregate Payment
    state
        public external_id: Text(len=64)?
        public human_ref: Text(len=64)?
        public provider: Text(len=64)
        public method: Text(len=64)
        public currency: Currency
        public authorized_amount_minor: Int
        public captured_amount_minor: Int
        public refunded_amount_minor: Int
        public state: Enum(AwaitingAuthorization, Authorized, Captured, Refunded, Void) = 'AwaitingAuthorization
        public allocations: List<PaymentAllocation>
        public created_at: Timestamp?
```

### Actions
```dhl
action AuthorizePayment(
    provider: Text(len=64),
    method: Text(len=64),
    currency: Currency,
    authorized_amount_minor: Int,
    external_id: Text(len=64)?,
    human_ref: Text(len=64)?
)
    validate
        state.created_at == null
        authorized_amount_minor >= 0
    apply
        state.provider = provider
        state.method = method
        state.currency = currency
        state.authorized_amount_minor = authorized_amount_minor
        state.captured_amount_minor = 0
        state.refunded_amount_minor = 0
        state.external_id = external_id
        state.human_ref = human_ref
        state.state = 'Authorized
        state.created_at = context.timestamp

action CapturePayment(captured_amount_minor: Int)
    validate
        state.state == 'Authorized
        captured_amount_minor >= 0
    apply
        state.captured_amount_minor = state.captured_amount_minor + captured_amount_minor
        state.state = 'Captured

action RefundPayment(
    refund_amount_minor: Int,
    final_state: Enum(AwaitingAuthorization, Authorized, Captured, Refunded, Void)
)
    validate
        state.state == 'Captured
        refund_amount_minor >= 0
        state.refunded_amount_minor + refund_amount_minor <= state.captured_amount_minor
        ((state.refunded_amount_minor + refund_amount_minor == state.captured_amount_minor) && (final_state == 'Refunded)) || ((state.refunded_amount_minor + refund_amount_minor < state.captured_amount_minor) && (final_state == 'Captured))
    apply
        state.refunded_amount_minor = state.refunded_amount_minor + refund_amount_minor
        state.state = final_state

action AllocatePayment(invoice_id: Ref<std.commerce.invoice>, amount_minor: Int)
    validate
        amount_minor > 0
    apply
        state.allocations.push(PaymentAllocation { invoice_id: invoice_id, amount_minor: amount_minor })

action VoidPayment()
    validate
        state.state == 'Authorized
    apply
        state.state = 'Void
```
