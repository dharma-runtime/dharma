### Private composed queries
#### Customer360(customer_id)
```dhl
query Customer360_OpenPOs(customer_id: Ref<std.iam.Identity>)
    private
    dhlq
    std.commerce.order.po
    | where customer_id == $1, status != 'Closed
```
```dhl
query Customer360_Invoices(customer_id: Ref<std.iam.Identity>)
    private
    dhlq
    std.commerce.invoice
    | lj std.commerce.order.po on po_id=std.commerce.order.po.subject
    | where std.commerce.invoice.state == 'Posted, std.commerce.order.po.customer_id == $1
```

#### OpsDashboard(date_from, date_to)
```dhl
query OpsDashboard_Lines(date_from: Timestamp, date_to: Timestamp)
    private
    dhlq
    std.commerce.order.line
    | where remaining_qty > 0, created_at between ($1,$2)
```
```dhl
query OpsDashboard_Batches(date_from: Timestamp, date_to: Timestamp)
    private
    dhlq
    std.commerce.logistics.batch
    | where scheduled_for between ($1,$2)
```

#### FinanceDashboard(date_from, date_to)
```dhl
query FinanceDashboard_Invoices(date_from: Timestamp, date_to: Timestamp)
    private
    dhlq
    std.commerce.invoice
    | where state == 'Posted, posted_at between ($1,$2)
```
```dhl
query FinanceDashboard_Payments(date_from: Timestamp, date_to: Timestamp)
    private
    dhlq
    std.commerce.payment
    | where state == 'Captured, created_at between ($1,$2)
```

#### VariantFillability(variant_id, qty, delivery_area?, bucket_date?)
```dhl
query VariantFillability(
    variant_id: Ref<std.commerce.catalog.variant>,
    qty: Decimal(scale=6),
    delivery_area: Text(len=64)?,
    bucket_date: Timestamp?
)
    private
    dhlq
    std.commerce.catalog.variant_availability
    | where variant_id == $1, bucket_date == $4
    | take 1
```

## Public vs private rule (summary)
- Public: customer browsing, tracking, and fiscal documents only. No lots, suppliers, warehouses, internal notes, matcher internals.
- Private: ops + finance + admin, including allocations, fulfillments, lot/expiry/supplier, diagnostics, and analytics.

## Code

### Types
```dhl


```

### Aggregate state
```dhl
aggregate PurchaseOrder
    state
        public external_id: Text(len=64)?
        public human_ref: Text(len=64)?
        public client_ref: SubjectRef<std.commerce.client>
        public client_group_ref: SubjectRef<std.commerce.client_group>
        public customer_id: Ref<std.iam.Identity>
        public channel_id: Text(len=64)?
        public currency: Currency
        public payment_ref: Ref<std.commerce.payment>?
        public payment_terms: Text(len=16)
        public reserve_on_accepted: Bool
        public reserve_timeout_accepted_hours: Int
        public reserve_on_authorized: Bool
        public reserve_timeout_authorized_hours: Int
        public reserve_on_captured: Bool
        public reserve_timeout_captured_hours: Int
        public post_capture_adjustment: Text(len=32)
        public status: Enum(Draft, Submitted, Accepted, Cancelled, Closed) = 'Draft
        public accepted_at: Timestamp?
        public authorized_at: Timestamp?
        public captured_at: Timestamp?
        public created_at: Timestamp?
        public created_by: Identity?
```

### Actions
```dhl
action Create(
    client_ref: SubjectRef<std.commerce.client>,
    customer_id: Ref<std.iam.Identity>,
    channel_id: Text(len=64)?,
    currency: Currency,
    external_id: Text(len=64)?,
    human_ref: Text(len=64)?
)
    validate
        state.created_at == null
        read_identity(client_ref, "identity_id") == customer_id
    apply
        state.client_ref = client_ref
        state.client_group_ref = read_subject_ref(client_ref, "group_ref")
        state.customer_id = customer_id
        state.channel_id = channel_id
        state.currency = currency
        state.payment_terms = read_text(state.client_group_ref, "payment_terms")
        state.reserve_on_accepted = read_bool(state.client_group_ref, "reserve_on_accepted")
        state.reserve_timeout_accepted_hours = read_int(state.client_group_ref, "reserve_timeout_accepted_hours")
        state.reserve_on_authorized = read_bool(state.client_group_ref, "reserve_on_authorized")
        state.reserve_timeout_authorized_hours = read_int(state.client_group_ref, "reserve_timeout_authorized_hours")
        state.reserve_on_captured = read_bool(state.client_group_ref, "reserve_on_captured")
        state.reserve_timeout_captured_hours = read_int(state.client_group_ref, "reserve_timeout_captured_hours")
        state.post_capture_adjustment = read_text(state.client_group_ref, "post_capture_adjustment")
        state.external_id = external_id
        state.human_ref = human_ref
        state.status = 'Draft
        state.created_at = context.timestamp
        state.created_by = context.signer

action Submit()
    validate
        state.status == 'Draft
    apply
        state.status = 'Submitted

action Accept()
    validate
        state.status == 'Submitted
    apply
        state.status = 'Accepted
        state.accepted_at = context.timestamp

action MarkAuthorized()
    validate
        state.status == 'Accepted
        state.authorized_at == null
    apply
        state.authorized_at = context.timestamp

action MarkCaptured()
    validate
        state.status == 'Accepted
        state.captured_at == null
    apply
        state.captured_at = context.timestamp

action LinkPayment(payment_ref: Ref<std.commerce.payment>)
    validate
        state.payment_ref == null
    apply
        state.payment_ref = payment_ref

action Cancel()
    validate
        (state.status == 'Draft) || (state.status == 'Submitted)
    apply
        state.status = 'Cancelled

action Close()
    validate
        state.status == 'Accepted
    apply
        state.status = 'Closed
```
