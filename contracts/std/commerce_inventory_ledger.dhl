projection LedgerReleaseFromAllocation
    trigger std.commerce.order.line.ReleaseAllocation
    batch_window 250ms
    max_delay 1s
    source state
    query
        std.commerce.order.line
        | explode allocations as allocation
        | lj std.commerce.inventory.sellable on allocation.sellable_id=std.commerce.inventory.sellable.subject
        | lj std.commerce.catalog.variant on std.commerce.inventory.sellable.variant_id=std.commerce.catalog.variant.subject
        | where allocation.status == 'Released
        | sel subject as line_id, allocation.allocation_id as allocation_id, allocation.qty_allocated as qty_allocated, std.commerce.inventory.sellable.batch_id as batch_id, std.commerce.catalog.variant.item_id as item_id, std.commerce.inventory.sellable.warehouse_id as warehouse_id
    emit upsert std.commerce.inventory.ledger
        id = proj_id("release_allocation", line_id, allocation_id)
        batch_id = batch_id
        item_id = item_id
        warehouse_id = warehouse_id
        entry_type = 'Release
        qty = 0 - qty_allocated
        expires_at = null
        ref_line_id = line_id
        ref_event_id = allocation_id
        reason = "release_allocation"

projection LedgerReleaseHoldAcceptedOnAuthorized
    trigger std.commerce.order.po.MarkAuthorized
    batch_window 250ms
    max_delay 1s
    source state
    query
        std.commerce.order.line
        | explode allocations as allocation
        | lj std.commerce.order.po on po_id=std.commerce.order.po.subject
        | lj std.commerce.inventory.sellable on allocation.sellable_id=std.commerce.inventory.sellable.subject
        | lj std.commerce.catalog.variant on std.commerce.inventory.sellable.variant_id=std.commerce.catalog.variant.subject
        | where allocation.status == 'Reserved,
                std.commerce.order.po.reserve_on_accepted == true,
                std.commerce.order.po.reserve_timeout_accepted_hours > 0,
                std.commerce.order.po.authorized_at != null,
                std.commerce.order.po.captured_at == null,
                std.commerce.order.po.authorized_at <= (std.commerce.order.po.accepted_at + (std.commerce.order.po.reserve_timeout_accepted_hours * 3600))
        | sel subject as line_id, allocation.allocation_id as allocation_id, allocation.qty_allocated as qty_allocated, std.commerce.inventory.sellable.batch_id as batch_id, std.commerce.catalog.variant.item_id as item_id, std.commerce.inventory.sellable.warehouse_id as warehouse_id
    emit upsert std.commerce.inventory.ledger
        id = proj_id("release_hold_accepted_authorized", line_id, allocation_id)
        batch_id = batch_id
        item_id = item_id
        warehouse_id = warehouse_id
        entry_type = 'Release
        qty = 0 - qty_allocated
        expires_at = null
        ref_line_id = line_id
        ref_event_id = allocation_id
        reason = "release_hold_accepted_authorized"

