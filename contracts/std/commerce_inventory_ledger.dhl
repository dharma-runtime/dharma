projection LedgerReserveHoldAuthorizedFromAllocation
    trigger std.commerce.order.line.ReserveAllocation
    trigger std.commerce.order.po.MarkAuthorized
    batch_window 250ms
    max_delay 1s
    source state
    query
        std.commerce.order.line
        | explode allocations as allocation
        | lj std.commerce.order.po on po_id=std.commerce.order.po.subject
        | lj std.commerce.inventory.sellable on allocation.sellable_id=std.commerce.inventory.sellable.subject
        | lj std.commerce.catalog.variant on std.commerce.inventory.sellable.variant_id=std.commerce.catalog.variant.subject
        | where allocation.status == 'Reserved,
                std.commerce.order.po.authorized_at != null,
                std.commerce.order.po.captured_at == null,
                std.commerce.order.po.reserve_on_authorized == true,
                std.commerce.order.po.reserve_timeout_authorized_hours > 0
        | sel subject as line_id, allocation.allocation_id as allocation_id, allocation.qty_allocated as qty_allocated, std.commerce.inventory.sellable.batch_id as batch_id, std.commerce.catalog.variant.item_id as item_id, std.commerce.inventory.sellable.warehouse_id as warehouse_id, std.commerce.order.po.authorized_at as authorized_at, std.commerce.order.po.reserve_timeout_authorized_hours as timeout_hours
    emit upsert std.commerce.inventory.ledger
        id = proj_id("reserve_hold_authorized", line_id, allocation_id)
        batch_id = batch_id
        item_id = item_id
        warehouse_id = warehouse_id
        entry_type = 'ReserveHold
        qty = qty_allocated
        expires_at = authorized_at + (timeout_hours * 3600)
        ref_line_id = line_id
        ref_event_id = allocation_id
        reason = "reserve_hold_authorized"

