        | sel subject as line_id, allocation.allocation_id as allocation_id, allocation.qty_allocated as qty_allocated, std.commerce.inventory.sellable.batch_id as batch_id, std.commerce.catalog.variant.item_id as item_id, std.commerce.inventory.sellable.warehouse_id as warehouse_id
