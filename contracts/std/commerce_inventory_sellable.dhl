### Aggregate state
```dhl
aggregate Sellable
    state
        public external_id: Text(len=64)?
        public human_ref: Text(len=64)?
        public sc: Text(len=64)?
        public sellable_type: Enum(Physical) = 'Physical
        public uom: Text(len=16)
        public variant_id: Ref<std.commerce.catalog.variant>
        public batch_id: Ref<std.commerce.inventory.batch>?
        public physical_identity: Text(len=128)?
        public lot_id: Text(len=64)?
        public expiry_date: Timestamp?
        public supplier_id: Ref<std.commerce.inventory.supplier>?
        public warehouse_id: Ref<std.commerce.logistics.warehouse>?
        public received_at: Timestamp?
        public attributes: Map<Text(len=64), Text(len=256)>
        public designation: Text(len=128)?
        public aging_actual_months: Int?
        public origin: Text(len=64)?
        public format: Text(len=64)?
        public temp_chain: Text(len=16)?
        public allergens_declared: Bool = false
        public allergens: List<Text(len=64)>
        public quantity_on_hand: Decimal(scale=6)
        public status: Enum(Available, Reserved, Picked, Shipped, Depleted, Archived) = 'Available
```

### Actions
```dhl
action Receive(
    sc: Text(len=64),
    variant_id: Ref<std.commerce.catalog.variant>,
    uom: Text(len=16),
    quantity_on_hand: Decimal(scale=6),
    batch_id: Ref<std.commerce.inventory.batch>?,
    physical_identity: Text(len=128)?,
    lot_id: Text(len=64)?,
    expiry_date: Timestamp?,
    supplier_id: Ref<std.commerce.inventory.supplier>?,
    warehouse_id: Ref<std.commerce.logistics.warehouse>?,
    received_at: Timestamp?,
    attributes: Map<Text(len=64), Text(len=256)>,
    designation: Text(len=128)?,
    aging_actual_months: Int?,
    origin: Text(len=64)?,
    format: Text(len=64)?,
    temp_chain: Text(len=16)?,
    allergens_declared: Bool,
    allergens: List<Text(len=64)>,
    external_id: Text(len=64)?,
    human_ref: Text(len=64)?
)
    validate
        state.sc == null
        quantity_on_hand >= 0
    apply
        state.sc = sc
        state.uom = uom
        state.variant_id = variant_id
        state.quantity_on_hand = quantity_on_hand
        state.batch_id = batch_id
        state.physical_identity = physical_identity
        state.lot_id = lot_id
        state.expiry_date = expiry_date
        state.supplier_id = supplier_id
        state.warehouse_id = warehouse_id
        state.received_at = received_at
        state.attributes = attributes
        state.designation = designation
        state.aging_actual_months = aging_actual_months
        state.origin = origin
        state.format = format
        state.temp_chain = temp_chain
        state.allergens_declared = allergens_declared
        state.allergens = allergens
        state.allergens.normalize()
        state.external_id = external_id
        state.human_ref = human_ref
        state.status = 'Available

action AdjustQty(
    qty_delta: Decimal(scale=6),
    new_status: Enum(Available, Reserved, Picked, Shipped, Depleted, Archived)
)
    validate
        state.status != 'Archived
        new_status != 'Archived
        state.quantity_on_hand + qty_delta >= 0
        ((state.quantity_on_hand + qty_delta == 0) && (new_status == 'Depleted)) || ((state.quantity_on_hand + qty_delta > 0) && (new_status != 'Depleted))
    apply
        state.quantity_on_hand = state.quantity_on_hand + qty_delta
        state.status = new_status

action UpdateAttributes(attributes: Map<Text(len=64), Text(len=256)>)
    validate
        state.status != 'Archived
    apply
        state.attributes = attributes

action UpdateAllergens(allergens_declared: Bool, allergens: List<Text(len=64)>)
    validate
        state.status != 'Archived
    apply
        state.allergens_declared = allergens_declared
        state.allergens = allergens
        state.allergens.normalize()

action Archive()
    validate
        state.status != 'Archived
    apply
        state.status = 'Archived
```
